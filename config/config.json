{
  "question": "",

  "llm_provider": "bedrock",
  "bedrock_model": "us.anthropic.claude-haiku-4-5-20251001-v1:0",
  "bedrock_region": "us-east-1",
  "bedrock_max_tokens": 16384,
  "bedrock_read_timeout": 600,
  "bedrock_connect_timeout": 10,
  "bedrock_retry_max_attempts": 0,

  "max_retries": 3,
  "retry_delay": 5,
  "responses_dir": "responses",
  "logs_dir": "logs",
  "news_analysis_prompt_path": "config/news_analysis_prompt.txt",
  "prompt_paths": {
    "daily": "config/news_analysis_prompt.txt",
    "weekly": "config/weekly_news_analysis_prompt.txt",
    "monthly": "config/monthly_news_analysis_prompt.txt"
  },
  "output_prefixes": {
    "daily": "daily",
    "weekly": "weekly",
    "monthly": "monthly"
  },

  "email_notification": {
    "enabled": true,
    "enabled_analysis_types": ["daily", "weekly", "monthly"],
    "ses_region": "ap-northeast-1",
    "sender": "ryusyukuri@gmail.com",
    "recipients": ["shiny.1k2no-meteor@ezweb.ne.jp", "ryu_syukuri@hotmail.co.jp"],
    "presigned_url_expires_seconds": 604800,
    "fail_on_send_error": false
  },

  "news_scraping": {
    "enabled": true,
    "scrape_yesterday_articles": true,
    "timezone": "Asia/Tokyo",
    "timeout_per_site": 30,
    "parallel_workers": 3,
    "max_articles_per_site": 30,
    "user_agent": "Mozilla/5.0 (compatible; NewsBot/1.0)",

    "content_fetching": {
      "enabled": true,
      "timeout_per_article": 10,
      "parallel_content_workers": 5,
      "max_content_length": 50000,
      "min_content_length": 200
    },

